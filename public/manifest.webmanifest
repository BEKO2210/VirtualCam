{
  "name": "CameraPrompt Pro",
  "short_name": "CameraPrompt",
  "description": "Modular camera prompt generator for AI image generation. 36 cameras, 80+ lenses, 21 genres, 462+ prompts. Mobile-first photographer studio.",
  "id": "./",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "orientation": "any",
  "background_color": "#0a0a0c",
